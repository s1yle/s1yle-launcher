{
  "name": "wecraft-launcher",
  "private": true,
  "version": "0.1.0-alpha.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "version:prepatch": "node scripts/bump-version.js prepatch",
    "version:preminor": "node scripts/bump-version.js preminor",
    "version:premajor": "node scripts/bump-version.js premajor",
    "version:prerelease": "node scripts/bump-version.js prerelease",
    "version:beta": "node scripts/bump-version.js prerelease beta",
    "version:rc": "node scripts/bump-version.js prerelease rc",
    "version:reset": "node scripts/bump-version.js reset alpha",
    "version:check": "node scripts/bump-version.js --dry-run",
    "generate-api": "bash scripts/generate-api.sh",
    "docs:gen": "pnpm docs:gen:api && pnpm docs:gen:rust && pnpm docs:gen:routes",
    "docs:gen:api": "typedoc --options typedoc.json",
    "docs:gen:rust": "cd src-tauri/ && cargo doc --open",
    "docs:gen:routes": "npx tsx scripts/generate-routes-doc.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "~2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "i18next": "^26.0.3",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.8",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "postcss-nested": "^7.0.2",
    "tailwindcss": "^4.1.18",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
