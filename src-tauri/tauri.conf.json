{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WeCraft-Launcher",
  "version": "0.1.0-alpha.2",
  "identifier": "art.wecraft.launcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WeCraft! Launcher - 登录",
        "width": 480,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": false,
        "theme": "Dark",
        "label": "login",
        "minWidth": 480,
        "minHeight": 640,
        "center": true,
        "focus": true,
        "visible": true,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "zoomHotkeysEnabled": false,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/backgrounds/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
