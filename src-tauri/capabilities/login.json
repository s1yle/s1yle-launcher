{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "login",
  "description": "Capability for the login window",
  "windows": ["login"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-set-size",
    "core:window:allow-set-resizable",
    "core:window:allow-set-focus",
    "core:window:allow-set-focusable",
    "core:window:allow-set-ignore-cursor-events",
    "dialog:default",
    "allow-greet",
    "allow-get-system-info",
    "allow-close-window",
    "allow-log-frontend",
    "allow-open-url",
    "allow-save-window-position",
    "allow-load-window-position",
    "allow-get-config",
    "allow-get-config-value",
    "allow-set-config-value",
    "allow-get-system-fonts",
    "allow-get-font",
    "allow-add-account",
    "allow-get-account-list",
    "allow-get-current-account",
    "allow-delete-account",
    "allow-set-current-account",
    "allow-save-accounts-to-disk",
    "allow-load-accounts-from-disk",
    "allow-save-login-state",
    "allow-clear-login-state",
    "allow-initialize-account-system",
    "allow-register-admin",
    "allow-login-admin",
    "allow-bind-player-to-admin",
    "allow-unbind-player-from-admin",
    "allow-get-admin-info",
    "allow-get-bound-players",
    "allow-is-admin-registered",
    "allow-initialize-admin-system",
    "allow-get-skin-model",
    "allow-render-isometric-avatar-cmd",
    "allow-get-uuid-by-username",
    "allow-switch-window"
  ]
}
